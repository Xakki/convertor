DOCKER_HOST=
DOCKER_USER=
DOCKER_PASS=

DOCKER_ENV=dev
COMPOSE_PROJECT_NAME=xakki-convertor
COMPOSE_PROFILES=dev
COMPOSE_FILE=docker-compose.yml

DOCKER_IMAGE_NGINX=harbor.xakki.ru/external/nginx
DOCKER_IMAGE_MARIADB=harbor.xakki.ru/external/mariadb:11
DOCKER_IMAGE_LIBRE=harbor.xakki.ru/library/libreoffice

APP_ENV=dev
TZ=UTC
APP_URL=http://localhost:9123

EXT_MYSQL_PORT=127.0.0.1:9112
EXT_NGINX_PORT=9113
EXT_LIBRE_PORT=127.0.0.1:9116

DB_HOST=mariadb
DB_USERNAME=convertor-dev
DB_DATABASE=convertor-dev
DB_PASSWORD=123456
DB_PASSWORD_ROOT=123456

# KeyDB (Redis-compatible) — replaces old REDIS_HOST=redis
REDIS_USERNAME=default
REDIS_PASSWORD=FdwDI2ke4WFDDDD
REDIS_HOST=keydb
# KeyDB databases: 0=cache, 1=sessions, 2=queues
REDIS_CACHE_DB=0
REDIS_SESSION_DB=1
REDIS_QUEUE_DB=2

SYSLOG_ADDR=udp://localhost:451

# PHP App / Symfony
SYMFONY_ENV=dev
JWT_SECRET_KEY=
JWT_PUBLIC_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=YouFileConvertBot

# Workers internal URLs (docker service hostnames)
WORKER_LIBREOFFICE_URL=http://worker-libreoffice:6001
WORKER_FFMPEG_URL=http://worker-ffmpeg:6001
WORKER_IMAGE_URL=http://worker-image:6001
WORKER_AI_URL=http://worker-ai:6001
WORKER_DATA_URL=http://worker-data:6001

# Shared file storage (mounted in php-fpm and all workers)
SHARE_DIR=/shared-files

# Whisper STT model size (tiny / base / small / medium / large)
WHISPER_MODEL=base

# AI API keys (для STT/TTS через облако когда нет локальных моделей)
GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
# AI provider: local | openai | gemini | claude (local = faster-whisper, приоритет по порядку)
AI_STT_PROVIDER=local
AI_TTS_PROVIDER=local

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=
