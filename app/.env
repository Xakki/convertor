###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_random_32_chars_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# MariaDB 11 — adjust host/port/dbname as needed
DATABASE_URL="mysql://app:password@mariadb:3306/convertor?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
REDIS_DSN=redis://keydb:6379
###< symfony/messenger ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
###< lexik/jwt-authentication-bundle ###

###> Telegram ###
TELEGRAM_BOT_TOKEN=your_bot_token_here
###< Telegram ###

###> Workers ###
WORKER_LIBREOFFICE_URL=http://libreoffice-worker:8000
WORKER_FFMPEG_URL=http://ffmpeg-worker:8000
WORKER_IMAGE_URL=http://image-worker:8000
WORKER_AI_URL=http://ai-worker:8000
WORKER_DATA_URL=http://data-worker:8000
###< Workers ###

###> Shared filesystem ###
SHARE_DIR=/shared-files
###< Shared filesystem ###
